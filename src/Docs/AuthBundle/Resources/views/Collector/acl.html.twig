{% extends 'WebProfilerBundle:Profiler:layout.html.twig' %}

{% block menu %}
    <span class="label">
        <span class="icon">
            <img src="data:image/png;base64,"/>
        </span>
        <strong>Permissions</strong>
    </span>
{% endblock %}

{% block panel %}
    <h2>List of pemissions</h2>

    <table>
        <tr>
            <th>Resource name</th>
            <th>Rights</th>
        </tr>
        {% for perm in collector.data.acl_permissions %}
            <tr>
                <td>{{ perm.ID }}</td>
                <td>{{ perm.Access }}</td>
            </tr>
        {% endfor %}
    </table>

{% endblock %}
